{
  "name": "ai-exam-grader",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "naps2:download": "node scripts/download-naps2.mjs",
    "electron:compile": "node scripts/build-electron.mjs",
    "electron:dev": "npm run electron:compile && concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && npm run electron:compile && electron-builder",
    "electron:build:win": "npm run naps2:download && next build && npm run electron:compile && electron-builder --win",
    "electron:build:mac": "next build && npm run electron:compile && electron-builder --mac",
    "electron:build:linux": "next build && npm run electron:compile && electron-builder --linux",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.3",
    "@types/uuid": "^10.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-pdf": "^10.3.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "unzipper": "^0.12.3",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.ai-exam-grader.app",
    "productName": "Gradely",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "!node_modules/**/*"
    ],
    "asarUnpack": [
      "out/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/logo.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.png",
      "extraResources": [
        {
          "from": "resources/naps2",
          "to": "naps2",
          "filter": [
            "**/*",
            "!Data",
            "!Data/**"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "guid": "com.ai-exam-grader.app",
      "artifactName": "Gradely.Setup.${env.NEXT_PUBLIC_APP_VERSION}.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dongho108",
        "repo": "ai-exam-grader",
        "releaseType": "release"
      }
    ],
    "protocols": [
      {
        "name": "AI Exam Grader",
        "schemes": [
          "ai-exam-grader"
        ]
      }
    ]
  }
}
